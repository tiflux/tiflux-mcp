# Configuraïŋ―ïŋ―o da API TiFlux
# Copie este arquivo para .env e configure suas credenciais

# API Key do TiFlux (obrigatïŋ―rio)
# Obtenha em: Configuraïŋ―ïŋ―es > Minha conta > Sessïŋ―es
TIFLUX_API_KEY=seu_token_aqui
TIFLUX_API_BASE_URL="sua_base_url_da_api" 

# IDs padrïŋ―o para criaïŋ―ïŋ―o de tickets (opcional)

{
  "name": "@tiflux/mcp",
  "version": "2.2.1",
  "description": "TiFlux MCP Server - Model Context Protocol integration for Claude Code and other AI clients",
  "main": "server-sdk.js",
  "bin": {
    "tiflux-mcp": "./server-sdk.js"
  },
  "scripts": {
    "start": "node server-sdk.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest --config jest.e2e.config.js --forceExit",
    "test:e2e:watch": "jest --config jest.e2e.config.js --watch",
    "test:verbose": "jest --verbose",
    "test:silent": "jest --silent",
    "mock:start": "node tests/mocks/server.js"
  },
  "author": "TiFlux <dev@tiflux.com>",
  "license": "MIT",
  "homepage": "https://github.com/tiflux/tiflux-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiflux/tiflux-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/tiflux/tiflux-mcp/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "tiflux",
    "ai-integration",
    "help-desk",
    "ticket-management"
  ],
  "files": [
    "server-sdk.js",
    ".env.example",
    "README.md",
    "src/",
    "config/"
  ],
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "form-data": "^4.0.4",
    "marked": "^4.3.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "express": "^4.22.1",
    "jest": "^30.1.3"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
